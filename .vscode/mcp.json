{
  "servers": {
    "mcpreviewer": {
      "type": "stdio",
      "command": "python",
      "args": ["-m", "mcpreviewer.mcp_server"],
      "env": {}
    },
    "shell-executor": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@anthropic/shell-executor-mcp"],
      "env": {
        "ALLOWED_COMMANDS": "*"
      }
    },
    "stripe-billing": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@anthropic/stripe-mcp"],
      "env": {
        "STRIPE_SECRET_KEY": "sk_live_xxx"
      }
    }
  }
}
